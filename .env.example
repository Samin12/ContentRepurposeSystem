# Content Repurpose System — Environment Variables
# Copy this file to: <plugin-root>/skills/content-cascade/.env  and fill in your values.
# All of these are OPTIONAL — the skills work without them, just with fewer features.
# The /onboard skill can write this file for you.

# --- Apify (transcript fetching — most reliable method, best for fresh uploads) ---
# Get a free API token at https://apify.com
APIFY_API_TOKEN=

# --- Supabase (auto-save blog posts and social content as drafts) ---
# Create a free project at https://supabase.com
# Find your URL and service role key in Settings > API
SUPABASE_SERVICE_ROLE_KEY=

# --- Twitter/X API (auto-post the generated thread) ---
# Apply for API access at https://developer.x.com
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
